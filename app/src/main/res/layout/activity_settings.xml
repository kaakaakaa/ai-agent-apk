<?xml version="1.0" encoding="utf-8"?>
<!-- File: app/src/main/res/layout/activity_settings.xml -->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- API 配置卡片 -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/api_config_title"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/primary_text" />

                <!-- 厂商选择 -->
                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:hint="选择大模型厂商"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu">

                    <AutoCompleteTextView
                        android:id="@+id/vendorSpinner"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="none" />

                </com.google.android.material.textfield.TextInputLayout>

                <!-- API Key 输入 -->
                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:hint="API Key"
                    app:passwordToggleEnabled="true"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/apiKeyInput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textPassword" />

                </com.google.android.material.textfield.TextInputLayout>

                <!-- 模型选择下拉框 -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/modelSpinnerLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:hint="选择模型"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                    android:visibility="gone">

                    <AutoCompleteTextView
                        android:id="@+id/modelSpinner"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="none" />

                </com.google.android.material.textfield.TextInputLayout>

                <!-- 测试 API 按钮 -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/testApiButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="测试 API 连接"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

                <!-- API 测试状态 -->
                <TextView
                    android:id="@+id/apiTestStatus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text=""
                    android:textColor="@color/secondary_text"
                    android:textSize="12sp"
                    android:visibility="gone" />

                <!-- 保存按钮 -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/saveApiKeyButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="保存 API Key" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- 模型配置卡片 -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/model_config_title"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/primary_text" />

                <!-- 模型选择 -->
                <RadioGroup
                    android:id="@+id/modelSelectionGroup"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp">

                    <RadioButton
                        android:id="@+id/autoModelRadio"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="自动选择（根据设备能力）" />

                    <RadioButton
                        android:id="@+id/cloudFirstRadio"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="优先使用云端模型" />

                    <RadioButton
                        android:id="@+id/localOnlyRadio"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="仅使用本地模型" />

                </RadioGroup>

                <!-- 本地模型状态 -->
                <TextView
                    android:id="@+id/localModelStatus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="本地模型：未加载"
                    android:textColor="@color/secondary_text" />

                <!-- 加载本地模型按钮 -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/loadLocalModelButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="加载本地模型（需要先下载模型文件）"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

                <!-- 模型下载提示 -->
                <TextView
                    android:id="@+id/modelDownloadHint"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="提示：本地模型文件较大，未包含在安装包中。\n建议使用云端模型（阿里云百炼、DeepSeek、Kimi），只需 API Key 即可使用。"
                    android:textColor="@color/secondary_text"
                    android:textSize="12sp" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- 语音配置卡片 -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/voice_config_title"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/primary_text" />

                <!-- 语音输入开关 -->
                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/voiceInputSwitch"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="启用语音输入" />

                <!-- 语音输出开关 -->
                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/voiceOutputSwitch"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="启用语音输出（TTS）" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- 关于卡片 -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/about_title"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/primary_text" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="AI Agent v1.0.0"
                    android:textColor="@color/secondary_text" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="支持多厂商大模型，本地 + 云端混合执行"
                    android:textColor="@color/secondary_text" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>

</ScrollView>
